{
  "name": "api",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "bun run src/db/migrate.ts",
    "seed:menu": "bun run src/scripts/seed-menu.ts",
    "seed:orders": "bun run src/scripts/seed-orders.ts",
    "test:s3": "bun run src/scripts/test-s3.ts",
    "test:presign": "bun run src/scripts/test-presign.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "hono": "^4.12.15",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2"
  }
}
